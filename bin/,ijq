#!/bin/bash
set -euo pipefail
args=()
flags=("")
history_file=/tmp/,ijq.out
input="."
pwd="$PWD"
for i in "$@"; do
  case "$i" in
  --redo) eval ": $(tail -1 $history_file)"; exit $? ;;
  --edit)
    pwd="$(tail -1 $history_file | sed 's/^; cd //g' | awk '{ print $1 }')"
    for f in $(tail -1 $history_file | sed 's/^.*cat //g; s/\|.*$//g'); do
      args+=("$f")
    done
    input="$(tail -1 $history_file | cut -d"'" -f2)" ;;
  -*)
    flags+=("$i")
    ;;
  *) args+=("$i");;
  esac
done
if [ "${#args[@]}" -eq 0 ]; then args=("*.json"); fi

tool="jq"
for arg in "${args[@]}"; do
  case "$arg" in
    *.yaml|*.yml) tool=yq
  esac
done
if ! command -v "$tool" >/dev/null; then
  echo "$tool not found" >&2
  exit 127
fi

query=;
read -r query < <(echo "" | fzf --query="$input" --print-query --preview "cat ${args[*]} | $tool ${flags[*]} {q}")
if [[ -n "$query" ]]; then
  cmd="cd $pwd && cat ${args[*]} | $tool ${flags[*]} '$query'"
  echo "; $cmd" | tee -a $history_file >&2
  eval "$cmd"
else
  echo "No query selected." >&2
  exit 1
fi
