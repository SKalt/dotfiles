#!/bin/bash
### $0 [-h|--help] [--edit] [--redo] [FLAGS] FILES
###
### interactive jq/yq wrapper.
###
### FLAGS
### -h | --help  print this message and exit
###      --edit  edit the last query
###      --redo  re-run the last query
### -*           pass flags to jq/yq
### -d | --debug debug
###
### FILES        json/yaml files to pass to jq/yq.

set -euo pipefail

usage() { grep '^###' "$0"  | sed 's/^### //g; s/^###//g'| sed "s#\$0#${0##*/}#g"; }

args=()
flags=("")
history_file=/tmp/,ijq.out
input="."
pwd="$PWD"
debug=false
for i in "$@"; do
  case "$i" in
  -h | --help) usage && exit 0;;
  --redo) eval ": $(tail -1 $history_file)"; exit $? ;;
  --edit)
    pwd="$(tail -1 $history_file | sed 's/^; cd //g' | awk '{ print $1 }')"
    for f in $(tail -1 $history_file | sed 's/^.*cat //g; s/\|.*$//g'); do
      args+=("$f")
    done
    input="$(tail -1 $history_file | cut -d"'" -f2)" ;;
  --debug)
    debug=true
    shift;;
  -*)
    flags+=("$i")
    ;;
  *) args+=("\"${i/\"/\\\"}\"");;
  esac
done
if [ "${#args[@]}" -eq 0 ]; then args=("*.json"); fi

tool="jq"
for arg in "${args[@]}"; do
  case "$arg" in
    *.yaml\"|*.yml\") tool=yq
  esac
done
if ! command -v "$tool" >/dev/null; then
  echo "$tool not found" >&2
  exit 127
fi

if [ "$debug" = "true" ]; then
    echo "args=${args[*]} tool=$tool"
    exit 0
fi

query=;
read -r query < <(echo "" | fzf --query="$input" --print-query --preview "cat ${args[*]} | $tool ${flags[*]} {q}")
if [[ -n "$query" ]]; then
  cmd="cd $pwd && cat ${args[*]} | $tool ${flags[*]} '$query'"
  echo "; $cmd" | tee -a $history_file >&2
  eval "$cmd"
else
  echo "No query selected." >&2
  exit 1
fi
