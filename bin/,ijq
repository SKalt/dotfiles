#!/bin/bash
set -euo pipefail
args=()
flags=("")
for i in "$@"; do
  case "$i" in
  -*)
    flags+=("$i")
    ;;
  *) args+=("$i");;
  esac
done
if [ "${#args[@]}" -eq 0 ]; then args=("*.json"); fi

query=;
read -r query < <(echo '' | fzf --print-query --preview "cat ${args[*]} | jq ${flags[*]} {q}")
if [[ -n "$query" ]]; then
  cmd="cat ${args[*]} | jq ${flags[*]} '$query'"
  echo "; $cmd" | tee -a /tmp/,ijq.out >&2
  eval "$cmd"
else
  echo "No query selected." >&2
  exit 1
fi
