#!/bin/bash
atuin search \
  --format '{directory}' \
  --after 'last week' |
    awk '
      BEGIN{ n=0 }
      { n++; x[$0]=n; }
      END {
        for (k in x) {
          print x[k] " " k
        }
      }
    ' |
    sort -nr |
    cut -d' ' -f2 |
    sed "s#$HOME/#~/#g" |
    fzf --query "$*"
